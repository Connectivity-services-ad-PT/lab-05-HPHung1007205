# API configuration
APP_HOST=0.0.0.0
APP_PORT=8000
AUTH_TOKEN=local-dev-token
SERVICE_NAME=iot-ingestion
SERVICE_VERSION=0.5.0
ENV=local

# Database configuration
POSTGRES_USER=lab05
POSTGRES_PASSWORD=lab05pass
POSTGRES_DB=iotdb

# Additional environment variables for AI service could be added here
# URL kết nối Database nội bộ Docker (Dùng tên service "db" làm host)
DATABASE_URL=postgresql://lab05:lab05pass@db:5432/iotdb

# URL kết nối sang AI service nội bộ Docker (Dùng tên service "ai-service" và port 9000)
AI_SERVICE_URL=http://ai-service:9000